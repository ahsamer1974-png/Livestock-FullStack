@model IEnumerable<LivestockMarketplaceApp.Models.Listing>

@{
    ViewData["Title"] = "إعلاناتي";
}

<div class="container mt-4" dir="rtl" style="text-align: right;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="fw-bold"><i class="bi bi-list-ul text-primary me-2"></i> إعلاناتي</h3>
        <a asp-action="Index" class="btn btn-outline-secondary btn-sm rounded-pill px-3">العودة للوحة التحكم</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-light text-center p-5 shadow-sm rounded-4 border-0 mt-4">
            <i class="bi bi-megaphone text-muted" style="font-size: 4rem;"></i>
            <h5 class="mt-3 text-muted fw-bold">ليس لديك أي إعلانات نشطة حالياً</h5>
            <p class="text-secondary mb-4">ابدأ الآن بعرض حلالك ليصل لآلاف المشترين المحتملين.</p>
            <a asp-controller="Listings" asp-action="Create" class="btn btn-primary btn-lg px-4 rounded-pill shadow-sm">
                <i class="bi bi-plus-circle me-1"></i> أضف إعلانك الأول
            </a>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden hover-card">

                        <div class="bg-light text-center d-flex align-items-center justify-content-center" style="height: 180px;">
                            @if (item.ListingImages != null && item.ListingImages.Any())
                            {
                                // إذا كان هناك صورة حقيقية للإعلان
                                <img src="@item.ListingImages.First().ImageUrl" alt="@item.Title" class="w-100 h-100" style="object-fit: cover;">
                            }
                            else
                            {
                                // صورة افتراضية في حال لم يرفع المستخدم صورة
                                <i class="bi bi-image text-secondary" style="font-size: 3.5rem;"></i>
                            }
                        </div>

                        <div class="card-body d-flex flex-column">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <h5 class="card-title fw-bold text-dark mb-0 text-truncate" style="max-width: 70%;">@item.Title</h5>
                                <span class="badge @(item.IsSold ? "bg-danger" : "bg-success") rounded-pill px-2 py-1">
                                    @(item.IsSold ? "مباع" : "نشط")
                                </span>
                            </div>

                            <p class="text-primary fw-bold fs-5 mb-2">@item.Price.ToString("0.##") ﷼</p>

                            <div class="text-muted small mb-3">
                                <div class="mb-1"><i class="bi bi-geo-alt me-1 text-secondary"></i> @(item.City ?? "غير محدد")</div>
                                <div><i class="bi bi-clock me-1 text-secondary"></i> @item.CreatedAt.ToString("yyyy/MM/dd")</div>
                            </div>

                            <div class="d-flex gap-2 mt-auto pt-3 border-top">
                                <a asp-controller="Listings" asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-primary btn-sm flex-fill rounded-pill fw-bold">
                                    <i class="bi bi-pencil-square"></i> تعديل
                                </a>
                                <a asp-controller="Listings" asp-action="Details" asp-route-id="@item.Id" class="btn btn-outline-secondary btn-sm flex-fill rounded-pill fw-bold">
                                    <i class="bi bi-eye"></i> عرض
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    /* تأثير جميل عند تمرير الماوس على الإعلان */
    .hover-card {
        transition: transform 0.3s ease, box-shadow 0.3s ease;
    }

        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
        }
</style>