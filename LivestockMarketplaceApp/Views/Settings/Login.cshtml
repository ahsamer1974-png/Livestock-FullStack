@{
    ViewData["Title"] = "تسجيل الدخول - سوق الحلال";
    // Layout = null;
}

<div class="container-fluid login-page-container p-0" dir="rtl">
    <div class="row g-0 h-100 align-items-center">

        <div class="col-lg-7 d-none d-lg-block h-100 login-bg-section position-relative">
            <div class="login-bg-overlay"></div>
            <div class="login-brand-content text-center p-5 z-2 position-relative d-flex flex-column h-100 justify-content-center">
                <a class="login-brand fs-1 fw-bolder text-decoration-none mb-4" asp-controller="Listings" asp-action="Index">
                    <i class="bi bi-shop text-success fs-1"></i> سوق الحلال
                </a>
                <h2 class="text-light fw-bold mb-3 h1">بوابتك الرقمية لسوق المواشي</h2>
                <p class="text-light fs-5 opacity-75">بيع، شراء، مراسلة، وطلب خدمات بكل سهولة وأمان.</p>
            </div>
        </div>

        <div class="col-lg-5 col-md-12 d-flex align-items-center justify-content-center h-100 bg-white shadow-lg p-5">
            <div class="login-form-wrapper w-100 text-end" style="max-width: 450px;">

                <div class="text-center mb-5 d-lg-none">
                    <a class="login-brand fs-1 fw-bolder text-decoration-none mb-4 text-dark" asp-controller="Listings" asp-action="Index">
                        <i class="bi bi-shop text-success fs-1"></i> سوق الحلال
                    </a>
                </div>

                <div class="mb-4">
                    <h1 class="h2 fw-bolder text-dark mb-2">تسجيل الدخول 🔐</h1>
                    <p class="text-muted">الرجاء إدخال بياناتك للوصول إلى حسابك.</p>
                </div>

                @if (ViewBag.Error != null)
                {
                    <div class="alert alert-danger d-flex align-items-center rounded-3 mb-4 border-0 shadow-sm" role="alert">
                        <i class="bi bi-exclamation-triangle-fill me-2 ms-2 fs-5"></i>
                        <div>@ViewBag.Error</div>
                    </div>
                }

                <form asp-controller="Settings" asp-action="LoginAction" method="post">
                    @Html.AntiForgeryToken()

                    <div class="form-group mb-4 position-relative text-end">
                        <label class="form-label fw-bold text-dark mb-2">البريد الإلكتروني</label>
                        <div class="input-group-custom">
                            <i class="bi bi-envelope input-icon text-muted"></i>
                            <input type="email" name="email" class="form-control premium-input ltr-input" placeholder="example@mail.com" required autocomplete="email">
                        </div>
                    </div>

                    <div class="form-group mb-4 position-relative text-end">
                        <label class="form-label fw-bold text-dark mb-2">كلمة المرور</label>
                        <div class="input-group-custom">
                            <i class="bi bi-lock input-icon text-muted"></i>
                            <input type="password" name="password" class="form-control premium-input ltr-input" placeholder="••••••••" required autocomplete="current-password">
                        </div>
                    </div>

                    <div class="form-group mt-5 mb-4">
                        <button type="submit" class="btn btn-login-premium w-100 rounded-pill fw-bold btn-lg">
                            <i class="bi bi-box-arrow-in-right me-2"></i> دخول
                        </button>
                    </div>

                    <div class="text-center mt-4 border-top pt-4">
                        <p class="text-muted mb-0">
                            ليس لديك حساب؟
                            <a asp-action="Register" class="text-decoration-none fw-bold ms-1" style="color: #D4AF37;">
                                إنشاء حساب جديد
                            </a>
                        </p>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .login-page-container {
        height: 100vh;
        overflow: hidden;
    }

    .login-bg-section {
        background-color: #1e293b;
        background-size: cover;
        background-position: center;
    }

    .login-bg-overlay {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background: linear-gradient(180deg, rgba(30, 41, 59, 0.7) 0%, rgba(15, 23, 42, 0.95) 100%);
        z-index: 1;
    }

    .login-brand {
        color: #fff !important;
        font-weight: 800;
        font-size: 32px;
    }

    .input-group-custom {
        position: relative;
    }

    /* تثبيت الأيقونات على اليسار إجبارياً */
    .input-icon {
        position: absolute;
        left: 20px !important;
        right: auto !important;
        top: 50%;
        transform: translateY(-50%);
        font-size: 20px;
        z-index: 10;
        color: #94a3b8;
        transition: color 0.3s ease;
    }

    /* ضبط مسافات الصندوق */
    .premium-input {
        border-radius: 50px !important;
        padding-top: 14px !important;
        padding-bottom: 14px !important;
        padding-right: 20px !important;
        padding-left: 55px !important; /* مساحة للأيقونة على اليسار */
        border: 2px solid #e2e8f0;
        background-color: #f8fafc;
        transition: all 0.3s ease;
        font-weight: 500;
    }

    /* 🔥 هذا الكلاس يجبر النص والنقاط تبدأ من اليسار بجانب الأيقونة 🔥 */
    .ltr-input {
        text-align: left !important;
        direction: ltr !important;
    }

        /* إجبار النص التوضيحي (placeholder) يبدأ من اليسار */
        .ltr-input::placeholder {
            text-align: left !important;
            direction: ltr !important;
            letter-spacing: normal;
        }

    /* تباعد نقاط الباسورد بشكل أجمل */
    input[type="password"].ltr-input {
        letter-spacing: 2px;
    }

    .premium-input:focus {
        border-color: #D4AF37;
        background-color: #fff;
        box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
        color: #1e293b;
        outline: none;
    }

        .premium-input:focus + .input-icon {
            color: #D4AF37 !important;
        }

    /* زر الدخول */
    .btn-login-premium {
        background: linear-gradient(135deg, #D4AF37, #f1c40f);
        color: white !important;
        border: none;
        box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
        transition: all 0.3s ease;
        padding: 12px 24px !important;
    }

        .btn-login-premium:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(212, 175, 55, 0.5);
            background: linear-gradient(135deg, #f1c40f, #D4AF37);
        }
</style>