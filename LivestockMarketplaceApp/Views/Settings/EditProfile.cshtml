@model LivestockMarketplaceApp.Models.User

@{
    ViewData["Title"] = "تعديل الملف الشخصي";
}

<div class="container mt-5" dir="rtl" style="text-align: right;">
    <div class="row justify-content-center">
        <div class="col-md-6 col-lg-5">
            <div class="card border-0 shadow-sm rounded-4 overflow-hidden">
                <div class="bg-primary p-4 text-center text-white">
                    <i class="bi bi-person-lines-fill" style="font-size: 3rem;"></i>
                    <h4 class="fw-bold mt-2 mb-0">تعديل البيانات</h4>
                </div>

                <div class="card-body p-4">
                    <form asp-action="EditProfile" method="post">
                        @Html.AntiForgeryToken()

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">الاسم الكامل</label>
                            <input asp-for="FullName" class="form-control bg-light" required>
                            <span asp-validation-for="FullName" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold text-secondary">رقم الجوال</label>
                            <input asp-for="PhoneNumber" class="form-control bg-light" required>
                            <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label fw-bold text-secondary">المدينة</label>
                            <input asp-for="City" class="form-control bg-light">
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary rounded-pill fw-bold">حفظ التعديلات</button>
                            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill">إلغاء والعودة</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>