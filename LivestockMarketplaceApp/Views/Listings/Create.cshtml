@model LivestockMarketplaceApp.Models.Listing

@{
    ViewData["Title"] = "إضافة إعلان جديد";
}

<div class="container mt-5 mb-5" dir="rtl">
    <div class="row justify-content-center">
        <div class="col-lg-10">

            <div class="card shadow-lg border-0 rounded-4 bg-white">
                <div class="card-body p-4 p-md-5">

                    <div class="mb-4 border-bottom pb-3 text-end">
                        <h2 class="fw-bolder text-dark mb-2">
                            <i class="bi bi-plus-circle-fill text-success me-2"></i> إضافة إعلان جديد للمواشي
                        </h2>
                        <p class="text-muted small mb-0">قم بتعبئة تفاصيل الحلال بدقة لزيادة فرص البيع السريع.</p>
                    </div>

                    <form asp-action="Create" enctype="multipart/form-data">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                        <div class="row g-4">
                            <div class="col-md-6">

                                <div class="form-group text-end position-relative">
                                    <label class="form-label fw-bold text-dark mb-2">عنوان الإعلان <span class="text-danger">*</span></label>
                                    <div class="input-group-custom">
                                        <i class="bi bi-card-heading input-icon text-muted"></i>
                                        <input asp-for="Title" class="form-control premium-input rtl-input" placeholder="مثال: خروف نعيمي طيب" required />
                                    </div>
                                    <span asp-validation-for="Title" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="form-group text-end position-relative mt-4">
                                    <label class="form-label fw-bold text-dark mb-2">القسم <span class="text-danger">*</span></label>
                                    <div class="input-group-custom">
                                        <i class="bi bi-grid input-icon text-muted"></i>
                                        <select asp-for="CategoryId" class="form-select premium-input rtl-input" asp-items="ViewBag.CategoryId" required>
                                            <option value="">-- اختر القسم --</option>
                                        </select>
                                    </div>
                                    <span asp-validation-for="CategoryId" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="form-group text-end position-relative mt-4">
                                    <label class="form-label fw-bold text-dark mb-2">السعر (ريال) <span class="text-danger">*</span></label>
                                    <div class="input-group-custom">
                                        <i class="bi bi-cash-coin input-icon text-muted"></i>
                                        <input asp-for="Price" class="form-control premium-input rtl-input" type="number" step="0.01" placeholder="0.00" required />
                                    </div>
                                    <span asp-validation-for="Price" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="form-group text-end position-relative mt-4">
                                    <label class="form-label fw-bold text-dark mb-2">الوصف <span class="text-danger">*</span></label>
                                    <div class="input-group-custom">
                                        <i class="bi bi-card-text input-icon text-muted" style="top: 22px; transform: none;"></i>
                                        <textarea asp-for="Description" class="form-control premium-input rtl-input" rows="4" placeholder="اكتب تفاصيل الإعلان، الحالة الصحية، الموقع بالتحديد..." required></textarea>
                                    </div>
                                    <span asp-validation-for="Description" class="text-danger small mt-1 d-block"></span>
                                </div>

                            </div>

                            <div class="col-md-6">

                                <div class="form-group text-end position-relative">
                                    <label class="form-label fw-bold text-dark mb-2">المدينة <span class="text-danger">*</span></label>
                                    <div class="input-group-custom">
                                        <i class="bi bi-geo-alt input-icon text-muted"></i>
                                        <input asp-for="City" class="form-control premium-input rtl-input" placeholder="الرياض، جدة، القصيم..." required />
                                    </div>
                                    <span asp-validation-for="City" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="form-group text-end position-relative mt-4">
                                    <label class="form-label fw-bold text-dark mb-2">العمر</label>
                                    <div class="input-group-custom">
                                        <i class="bi bi-calendar-event input-icon text-muted"></i>
                                        <input asp-for="Age" class="form-control premium-input rtl-input" placeholder="مثال: 6 شهور، جذع، ثني..." />
                                    </div>
                                    <span asp-validation-for="Age" class="text-danger small mt-1 d-block"></span>
                                </div>

                                <div class="form-group text-end position-relative mt-4">
                                    <label class="form-label fw-bold text-dark mb-2">صور الماشية <span class="text-danger">*</span></label>
                                    <div class="input-group-custom file-upload-wrapper">
                                        <i class="bi bi-images input-icon text-muted" style="z-index: 5;"></i>
                                        <input type="file" name="images" class="form-control premium-input rtl-input" multiple accept="image/*" required />
                                    </div>
                                    <div class="alert alert-info small mt-2 py-2 border-0 mb-0">
                                        <i class="bi bi-info-circle-fill me-1"></i> يمكنك اختيار أكثر من صورة. يفضل رفع صور واضحة للحلال من عدة زوايا.
                                    </div>
                                </div>

                                <div class="form-group mt-5">
                                    <button type="submit" class="btn btn-login-premium btn-lg w-100 rounded-3 fw-bold mb-3 shadow-sm">
                                        <i class="bi bi-send me-2"></i> نشر الإعلان
                                    </button>

                                    <a asp-action="Index" class="btn btn-light btn-lg w-100 rounded-3 fw-bold text-secondary" style="border: 2px solid #e2e8f0;">
                                        <i class="bi bi-x-circle me-2"></i> إلغاء والعودة
                                    </a>
                                </div>

                            </div>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>

<style>
    .input-group-custom {
        position: relative;
    }

    /* 🔥 نقلنا الأيقونات لليسار عشان ما تزاحم النص العربي 🔥 */
    .input-icon {
        position: absolute;
        left: 16px !important;
        right: auto !important;
        top: 50%;
        transform: translateY(-50%);
        font-size: 18px;
        z-index: 4;
        color: #94a3b8;
        transition: color 0.3s ease;
    }

    /* تصميم الحقل المميز */
    .premium-input {
        border-radius: 12px !important;
        padding-top: 12px !important;
        padding-bottom: 12px !important;
        padding-right: 20px !important; /* الكلمة تبدأ من أقصى اليمين مباشرة */
        padding-left: 48px !important; /* مساحة للأيقونة في اليسار */
        border: 2px solid #e2e8f0;
        background-color: #f8fafc;
        transition: all 0.3s ease;
        font-weight: 500;
        color: #334155;
    }

    /* إصلاح حقل رفع الملفات ليتناسق مع الأيقونة في اليسار */
    .file-upload-wrapper input[type="file"] {
        padding-left: 48px !important;
        line-height: 1.5;
    }

    /* محاذاة النص العربي لليمين بشكل إجباري */
    .rtl-input {
        text-align: right !important;
        direction: rtl !important;
    }

        .rtl-input::placeholder {
            text-align: right !important;
            color: #94a3b8;
            font-weight: normal;
        }

    /* تغيير لون الإطار عند التركيز */
    .premium-input:focus {
        border-color: #D4AF37;
        background-color: #fff;
        box-shadow: 0 0 0 4px rgba(212, 175, 55, 0.15);
        color: #1e293b;
        outline: none;
    }

        .premium-input:focus + .input-icon,
        .premium-input:focus ~ .input-icon {
            color: #D4AF37 !important;
        }

    /* الزر الذهبي النابض */
    .btn-login-premium {
        background: linear-gradient(135deg, #D4AF37, #f1c40f);
        color: white !important;
        border: none;
        transition: all 0.3s ease;
    }

        .btn-login-premium:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(212, 175, 55, 0.4) !important;
            background: linear-gradient(135deg, #f1c40f, #D4AF37);
        }

    .btn-light:hover {
        background-color: #e2e8f0;
        color: #1e293b !important;
    }
</style>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}