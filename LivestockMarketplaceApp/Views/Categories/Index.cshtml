@model IEnumerable<LivestockMarketplaceApp.Models.Category>

@{
    ViewData["Title"] = "أقسام الحلال";
}

<div class="container mt-5" dir="rtl">
    
    <div class="d-flex justify-content-between align-items-center mb-5 pb-3 border-bottom">
        <h1 class="fw-bolder text-dark m-0">
            <i class="bi bi-grid-fill text-success me-2"></i> أقسام الحلال
        </h1>
        <a asp-action="Create" class="btn btn-add rounded-pill fw-bold">
            <i class="bi bi-plus-circle me-2"></i> إضافة قسم جديد
        </a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center rounded-4 shadow-sm p-5" role="alert">
            <i class="bi bi-info-circle fs-1 mb-3 d-block text-secondary"></i>
            <h4 class="fw-bold text-dark">لا توجد أقسام حالياً</h4>
            <p class="text-muted">ابدأ بإضافة أول قسم لعرضه هنا.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var item in Model)
            {
                <div class="col-xl-3 col-lg-4 col-md-6 col-sm-6">
                    <div class="card h-100 category-card shadow-sm border-0 rounded-4 text-center">
                        <div class="card-body p-4 d-flex flex-column align-items-center justify-content-center">
                            
                            <div class="category-icon-wrapper rounded-circle d-flex align-items-center justify-content-center mb-4">
                                @if (string.IsNullOrEmpty(item.IconUrl))
                                {
                                    <i class="bi bi-tag-fill fs-2 text-success"></i>
                                }
                                else
                                {
                                    <img src="@item.IconUrl" class="img-fluid category-icon-img" alt="@item.Name" />
                                }
                            </div>

                            <h5 class="card-title fw-bold text-dark mb-4 px-2">@item.Name</h5>
                            
                            <div class="category-actions w-100 mt-auto pt-3 border-top">
                                <div class="d-grid gap-2 d-flex justify-content-center">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-outline-info btn-sm rounded-pill px-3 fw-bold">
                                        <i class="bi bi-pencil-square"></i> تعديل
                                    </a>
                                    @* <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-outline-danger btn-sm rounded-pill px-3 fw-bold">
                                        <i class="bi bi-trash"></i> حذف
                                    </a> *@
                                </div>
                            </div>

                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<style>
    /* زر الإضافة الذهبي المتميز */
    .btn-add {
        background: linear-gradient(135deg, #D4AF37, #f1c40f);
        color: white !important;
        border: none;
        box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
        transition: all 0.3s ease;
        padding: 10px 24px !important;
    }

    .btn-add:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(212, 175, 55, 0.4);
        background: linear-gradient(135deg, #f1c40f, #D4AF37);
    }

    /* تصميم بطاقة القسم المميزة */
    .category-card {
        transition: all 0.3s ease;
        background-color: #fff;
    }

    /* تأثير التمرير على البطاقة */
    .category-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08) !important;
        border-color: #D4AF37 !important;
    }

    /* إطار الأيقونة الدائري */
    .category-icon-wrapper {
        width: 110px;
        height: 110px;
        background-color: #e6f7ed; /* خلفية خضراء فاتحة ناعمة */
        overflow: hidden;
        border: 4px solid #fff;
        box-shadow: 0 4px 15px rgba(0,0,0,0.05);
        transition: all 0.3s ease;
    }
    
    .category-card:hover .category-icon-wrapper {
        border-color: #e6f7ed;
    }

    /* ضبط الصورة داخل الإطار */
    .category-icon-img {
        max-width: 70%;
        max-height: 70%;
        object-fit: contain;
    }

    /* تصميم أزرار الإجراءات */
    .category-actions .btn-outline-info {
        border-color: #e2e8f0;
        color: #64748b;
        font-size: 0.85rem;
    }
    
    .category-actions .btn-outline-info:hover {
        background-color: #0dcaf0;
        border-color: #0dcaf0;
        color: #fff;
    }
</style>