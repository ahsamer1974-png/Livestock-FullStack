<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - سوق الحلال</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.rtl.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

    <style>
        html, body {
            height: 100%;
        }

        body {
            display: flex;
            flex-direction: column;
            background: linear-gradient(135deg, #f8fafc, #eef2f7);
            font-family: 'Segoe UI', Tahoma, Arial, sans-serif;
        }

        .container {
            flex: 1;
        }

        /* NAVBAR PREMIUM DESIGN */
        .navbar-custom {
            background: rgba(255, 255, 255, 0.98) !important;
            backdrop-filter: blur(15px);
            box-shadow: 0 4px 25px rgba(0, 0, 0, 0.06);
            border-bottom: 3px solid #D4AF37; /* لمسة ذهبية أسفل القائمة */
            padding: 12px 0;
            transition: all 0.3s ease;
        }

        .navbar-brand {
            font-weight: 800;
            font-size: 24px;
            color: #1e293b !important;
            transition: transform 0.3s ease;
        }

            .navbar-brand:hover {
                transform: scale(1.03);
            }

            .navbar-brand i {
                margin-left: 5px;
                font-size: 26px;
            }

        .nav-link {
            position: relative;
            margin: 0 5px;
            padding: 8px 16px !important;
            font-weight: 600;
            color: #475569 !important;
            border-radius: 8px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
        }

            .nav-link i {
                margin-left: 6px;
                font-size: 18px;
                color: #94a3b8;
                transition: all 0.3s ease;
            }

            /* تأثير التمرير على الروابط */
            .nav-link:hover {
                background-color: #f8fafc;
                color: #D4AF37 !important;
            }

                .nav-link:hover i {
                    color: #D4AF37;
                    transform: scale(1.1);
                }

        /* زر الإعلان المميز */
        .btn-add {
            background: linear-gradient(135deg, #D4AF37, #f1c40f);
            border-radius: 50px;
            padding: 10px 24px;
            color: white !important;
            font-weight: 700;
            display: flex;
            align-items: center;
            box-shadow: 0 4px 15px rgba(212, 175, 55, 0.3);
            transition: all 0.3s ease;
            text-decoration: none;
            border: 2px solid transparent;
        }

            .btn-add i {
                margin-left: 8px;
                font-size: 18px;
            }

            .btn-add:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 25px rgba(212, 175, 55, 0.5);
                background: linear-gradient(135deg, #f1c40f, #D4AF37);
            }

        /* FOOTER */
        .footer {
            background: linear-gradient(135deg, #1e293b, #0f172a);
            color: #fff;
            padding: 40px 0 20px;
            margin-top: auto;
        }

        .footer-title {
            font-weight: bold;
            margin-bottom: 15px;
            color: #D4AF37;
        }

        .footer-links {
            list-style: none;
            padding: 0;
        }

            .footer-links li {
                margin-bottom: 8px;
            }

            .footer-links a {
                color: #cbd5e1;
                text-decoration: none;
                transition: 0.3s;
            }

                .footer-links a:hover {
                    color: #D4AF37;
                    padding-right: 5px;
                }

        .social-icons i {
            font-size: 20px;
            margin-left: 15px;
            cursor: pointer;
            transition: 0.3s;
            color: #cbd5e1;
        }

            .social-icons i:hover {
                color: #D4AF37;
                transform: scale(1.2);
            }

        .footer hr {
            border-color: rgba(255,255,255,0.1);
        }
    </style>

    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <nav class="navbar navbar-expand-lg sticky-top navbar-custom">
        <div class="container">

            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <i class="bi bi-shop text-success"></i> سوق الحلال
            </a>

            <button class="navbar-toggler border-0 shadow-none" type="button" data-bs-toggle="collapse" data-bs-target="#nav">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div id="nav" class="collapse navbar-collapse justify-content-between mt-3 mt-lg-0">

                <ul class="navbar-nav align-items-lg-center">
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Listings" asp-action="Index">
                            <i class="bi bi-house-door"></i> الرئيسية
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Categories" asp-action="Index">
                            <i class="bi bi-grid"></i> الأقسام
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Messages" asp-action="Index">
                            <i class="bi bi-chat-dots"></i> الرسائل
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Favorites" asp-action="Index">
                            <i class="bi bi-star"></i> المفضلة
                        </a>
                    </li>

                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Settings" asp-action="Index">
                            <i class="bi bi-gear"></i> الإعدادات
                        </a>
                    </li>
                </ul>

                <div class="mt-3 mt-lg-0">
                    <a class="btn-add" asp-controller="Listings" asp-action="Create">
                        <i class="bi bi-plus-circle"></i> أضف إعلان
                    </a>
                </div>

            </div>
        </div>
    </nav>

    <div class="container mt-4 mb-5">
        @RenderBody()
    </div>

    <footer class="footer">
        <div class="container">
            <div class="row text-center text-md-start">

                <div class="col-md-4 mb-4">
                    <h5 class="footer-title">سوق الحلال</h5>
                    <p class="text-light" style="opacity: 0.8;">
                        منصة لبيع وشراء المواشي بكل سهولة وأمان داخل المملكة.
                    </p>
                </div>

                <div class="col-md-4 mb-4">
                    <h5 class="footer-title">روابط مهمة</h5>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index">الرئيسية</a></li>
                        <li><a href="#">من نحن</a></li>
                        <li><a href="#">الدعم</a></li>
                        <li><a asp-controller="Home" asp-action="Privacy">سياسة الخصوصية</a></li>
                    </ul>
                </div>

                <div class="col-md-4 mb-4">
                    <h5 class="footer-title">تواصل معنا</h5>
                    <p style="opacity: 0.8;"><i class="bi bi-envelope me-2"></i> support@halal.com</p>
                    <p style="opacity: 0.8;"><i class="bi bi-phone me-2"></i> 0500000000</p>

                    <div class="social-icons mt-3">
                        <i class="bi bi-twitter-x"></i>
                        <i class="bi bi-instagram"></i>
                        <i class="bi bi-snapchat"></i>
                    </div>
                </div>

            </div>

            <hr>

            <div class="text-center" style="opacity: 0.7; font-size: 0.9rem;">
                &copy; 2026 سوق الحلال - جميع الحقوق محفوظة
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>